{
	"name": "loaphuong",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --hot src/index.ts",
		"start": "NODE_ENV=production bun src/index.ts",
		"build:linux": "bun build --compile --target=bun-linux-x64 src/main.ts --outfile=loaphuong",
		"build:win": "bun build --compile --target=bun-windows-x64 src/main.ts --outfile=loaphuong",
		"build:win:icon": "bun build --compile --target=bun-windows-x64 --windows-hide-console --windows-description=\"loaphuong NEUTRINO SVS Server\" --windows-version=1.0.0.0 src/main.ts --outfile=loaphuong",
		"dist": "bash scripts/build-dist.sh",
		"lint": "oxlint --type-aware --import-plugin --react-plugin",
		"fmt": "oxfmt"
	},
	"dependencies": {
		"@xmldom/xmldom": "^0.9.10"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"oxfmt": "^0.52.0",
		"oxlint": "^1.67.0",
		"oxlint-tsgolint": "^0.23.0"
	}
}
